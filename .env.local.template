# Muntada Local Development Environment Configuration
# Copy this file to .env.local and adjust values as needed.
# .env.local is gitignored and will NOT be committed.

# =============================================================================
# NOTE: When using Aspire (primary method), most connection strings are
# injected automatically via service discovery. These values are primarily
# for Docker Compose fallback mode.
# =============================================================================

# SQL Server
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=YourStrong!Passw0rd
SQL_SERVER_DATABASE=MuntadaDb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=muntada-files

# LiveKit (self-hosted OSS)
LIVEKIT_HOST=localhost
LIVEKIT_PORT=7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Application
BACKEND_PORT=5000
FRONTEND_PORT=3000
ASPIRE_DASHBOARD_PORT=18888

# Docker Hub (CI/CD only — not needed for local dev)
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=

# OpenTelemetry (Aspire handles this in dev — only for Docker Compose fallback)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
